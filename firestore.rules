rules_version = '2';

// Copy/paste this into: Firebase Console → Firestore Database → Rules
//
// This requires the user to be signed in (the app signs everyone in
// anonymously automatically), which blocks random internet bots from
// reading/writing your database. It does NOT distinguish between admin
// and parent roles — see the security note in README.md.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
